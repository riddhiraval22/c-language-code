{% extends 'header.html' %}
{% block content %}
<!DOCTYPE html>
<html lang="en">
<head>
  <title>Bootstrap Example</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  
</head>
<body>
<h1>Forgot Password </h1>
  {% if msg %}
    <b style="color: blue;">{{msg}}</b>
  {% endif %}
<form name="'signup" method ="post" action="{% url 'forgot-password' %}" enctype="multipart/form-data">
{% csrf_token %}
<table>
    <tr>
        <td>Email</td>
        <td><input type="text" name="email"></td>
    </tr>    
    <tr>
        <td>
            <input type="submit" value="Send OTP" class="btn btn-primary">

        </td>
       
    </tr>
</table>    


</form>

</body>
</html>
{% endblock %}